# PostgreSQL database URI (Using dedicated user and database name)
DATABASE_URL="postgresql://restaurant_app:YOUR_STRONG_PASSWORD@database-1.chm6wgs2iiu7.ap-south-1.rds.amazonaws.com:5432/restaurant_management?schema=public"

# Node Settings
PORT=3000
NODE_ENV=development

# Security Keys
JWT_SECRET="generate-a-long-secure-access-jwt-secret-string-here"
JWT_REFRESH_SECRET="generate-a-long-secure-refresh-jwt-secret-string-here"
MOBILE_APP_API_KEY="generate-a-long-random-traffic-filtering-string-here"

# Admin Bootstrap Credentials (created if admin count is 0)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="super-secure-change-this-password"

# Nginx/CORS Settings
CORS_ORIGIN="http://localhost:5173"
SSL_EMAIL="admin@your-restaurant.com"
