datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum OrderStatus {
  open
  hold
  billed
  paid
}

enum TableStatus {
  empty
  active
  bill
  paid
}

enum PaymentMethod {
  cash
  upi
  card
  credit
}

model Admin {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username     String     @unique
  passwordHash String     @map("password_hash")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  auditLogs    AuditLog[]

  @@map("admins")
}

model Category {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  icon      String
  sortOrder Int        @default(0) @map("sort_order")
  isDeleted Boolean    @default(false) @map("is_deleted")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  menuItems MenuItem[]

  @@map("categories")
}

model MenuItem {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId  String      @map("category_id") @db.Uuid
  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name        String
  price       Decimal     @db.Decimal(10, 2)
  emoji       String?
  isAvailable Boolean     @default(true) @map("is_available")
  isVeg       Boolean     @default(true) @map("is_veg")
  isDeleted   Boolean     @default(false) @map("is_deleted")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  orderItems  OrderItem[]

  @@index([categoryId])
  @@map("menu_items")
}

model Table {
  id             Int         @id @default(autoincrement())
  name           String
  seats          Int         @default(4)
  status         TableStatus @default(empty)
  currentOrderId String?     @map("current_order_id") @db.Uuid
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  orders         Order[]

  @@map("tables")
}

model Order {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tableId       Int?           @map("table_id")
  table         Table?         @relation(fields: [tableId], references: [id], onDelete: SetNull)
  orderNo       String         @unique @map("order_no")
  guests        Int            @default(1)
  status        OrderStatus    @default(open)
  subtotal      Decimal        @default(0.00) @db.Decimal(10, 2)
  gstAmount     Decimal        @default(0.00) @map("gst_amount") @db.Decimal(10, 2)
  total         Decimal        @default(0.00) @db.Decimal(10, 2)
  openedAt      DateTime       @default(now()) @map("opened_at")
  closedAt      DateTime?      @map("closed_at")
  paymentMethod PaymentMethod? @map("payment_method")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  items         OrderItem[]

  @@index([openedAt])
  @@index([status])
  @@index([tableId])
  @@map("orders")
}

model OrderItem {
  id         Int       @id @default(autoincrement())
  orderId    String    @map("order_id") @db.Uuid
  order      Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String?   @map("menu_item_id") @db.Uuid
  menuItem   MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  name       String
  price      Decimal   @db.Decimal(10, 2)
  qty        Int       @default(1)
  notes      String?

  @@index([orderId])
  @@map("order_items")
}

model Invoice {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId       String        @map("order_id") @db.Uuid
  tableId       Int           @map("table_id")
  orderNo       String        @map("order_no")
  invoiceNo     String        @unique @map("invoice_no")
  subtotal      Decimal       @db.Decimal(10, 2)
  gstAmount     Decimal       @map("gst_amount") @db.Decimal(10, 2)
  total         Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod @map("payment_method")
  createdAt     DateTime      @default(now()) @map("created_at")
  items         InvoiceItem[]

  @@index([createdAt])
  @@map("invoices")
}

model InvoiceItem {
  id         Int     @id @default(autoincrement())
  invoiceId  String  @map("invoice_id") @db.Uuid
  invoice    Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  menuItemId String? @map("menu_item_id") @db.Uuid
  name       String
  price      Decimal @db.Decimal(10, 2)
  qty        Int

  @@map("invoice_items")
}

model Setting {
  id             Int      @id @default(autoincrement())
  restaurantName String   @map("restaurant_name")
  address        String
  gstNumber      String   @map("gst_number")
  gstPercent     Decimal  @default(5.00) @map("gst_percent") @db.Decimal(5, 2)
  currency       String   @default("INR")
  tableCount     Int      @default(12) @map("table_count")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  adminId    String?  @map("admin_id") @db.Uuid
  admin      Admin?   @relation(fields: [adminId], references: [id], onDelete: SetNull)
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}
